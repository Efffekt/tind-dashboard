{
  "crons": [
    {
      "path": "/api/data",
      "schedule": "*/3 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/login.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=180, stale-while-revalidate=60" }
      ]
    }
  ]
}
